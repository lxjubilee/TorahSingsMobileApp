# Copy to `.env` and fill in. The real `.env` is gitignored.
# These are injected into Expo `extra` by app.config.js at build/start time.

# JubileeInspire service-to-service client secret (password sync).
JI_SERVICE_CLIENT_SECRET=

# Mobile client key to skip Turnstile on prod /api/auth/mobile/login (optional).
AUTH_MOBILE_CLIENT_KEY=
